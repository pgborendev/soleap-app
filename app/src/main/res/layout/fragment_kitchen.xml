<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background" android:orientation="vertical"
    android:gravity="center" android:padding="32dp">
    <TextView android:text="👨‍🍳" android:textSize="64sp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:text="Kitchen Display System" android:textColor="@color/text_primary"
        android:textSize="22sp" android:textStyle="bold"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="16dp"/>
    <TextView android:text="Open the full KDS view (landscape mode)\nfor kitchen staff" android:textColor="@color/text_secondary"
        android:textSize="14sp" android:gravity="center"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="8dp" android:layout_marginBottom="24dp"/>
    <Button android:id="@+id/btnOpenKDS" android:layout_width="match_parent" android:layout_height="52dp"
        android:text="Open Kitchen Display" android:backgroundTint="@color/amber"
        android:textColor="@color/white" android:textStyle="bold"
        style="@style/Widget.MaterialComponents.Button"/>
</LinearLayout>
