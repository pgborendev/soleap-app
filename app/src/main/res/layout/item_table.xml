<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card"
    android:layout_width="match_parent" android:layout_height="130dp"
    android:layout_margin="6dp" android:clickable="true" android:focusable="true"
    app:cardBackgroundColor="@color/surface" app:cardElevation="0dp"
    app:strokeWidth="2dp" app:cardCornerRadius="14dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:padding="14dp" android:gravity="center_vertical">
        <TextView android:id="@+id/tvName" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvCapacity" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginTop="2dp"/>
        <TextView android:id="@+id/tvFloor" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_hint" android:textSize="11sp"/>
        <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="12sp" android:textStyle="bold" android:layout_marginTop="6dp"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
