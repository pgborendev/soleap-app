<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background" android:gravity="center" android:orientation="vertical">
    <TextView android:text="🍽️" android:textSize="80sp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:text="Restaurant POS" android:textColor="@color/text_primary"
        android:textSize="28sp" android:textStyle="bold"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="16dp"/>
    <TextView android:text="Powered by ERPNext URYPOS" android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="8dp"/>
    <ProgressBar android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="48dp" android:indeterminateTint="@color/primary"/>
</LinearLayout>
