<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Top Navigation Tabs -->
    <!-- Top Navigation Tabs -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/mainTabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:tabTextColor="#757575"
        app:tabSelectedTextColor="#2563EB"
        app:tabIconTint="@color/tab_color_selector"
        app:tabIndicatorColor="#2563EB"
        app:tabIndicatorHeight="3dp"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabMaxWidth="0dp"
        app:tabPaddingStart="8dp"
        app:tabPaddingEnd="8dp"
        app:tabTextAppearance="@style/CustomTabTextAppearance"
        app:tabIconTintMode="src_atop"
        app:tabIndicatorFullWidth="true">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:icon="@drawable/ic_layout_grid"
            android:text="@string/place_new_order" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:icon="@drawable/ic_table_layout"
            android:text="@string/table_layout" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:icon="@drawable/ic_orders"
            android:text="@string/orders_list" />

    </com.google.android.material.tabs.TabLayout>

    <!-- Content Area -->
    <FrameLayout
        android:id="@+id/tabContentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/mainTabLayout">

        <!-- 1. POS TAB SECTION -->
        <LinearLayout
            android:id="@+id/layoutPOS"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Course Chips (Top) -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:scrollbars="none">
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/cgCourses"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true" />
            </HorizontalScrollView>

            <!-- Menu Item Grid (Middle) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProductGrid"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="4dp" />

            <!-- Charge Button (Bottom) -->
            <Button
                android:id="@+id/btnCharge"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_margin="12dp"
                android:backgroundTint="#4CAF50"
                android:text="CHARGE $0.00"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 2. TABLE LAYOUT TAB SECTION -->
        <LinearLayout
            android:id="@+id/layoutTables"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTableGrid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp" />
        </LinearLayout>

        <!-- 3. ORDERS TAB SECTION -->
        <LinearLayout
            android:id="@+id/layoutOrders"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvOrdersList"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp" />
        </LinearLayout>

    </FrameLayout>
</RelativeLayout>